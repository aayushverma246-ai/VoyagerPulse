# Supabase Connection Settings (Direct Connection & Connection Pooling via Prisma)
DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Webhook and Client configuration
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"

# Cookie Encryption Secret
ENCRYPTION_KEY="[HEX-ENCRYPTION-KEY-MUST-BE-32-BYTES-64-HEX-CHARS]"

# NextAuth or App Settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
